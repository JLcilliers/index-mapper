generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model GoogleConnection {
  id           String   @id @default(cuid())
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  email        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id          String   @id @default(cuid())
  name        String
  domain      String
  niche       String?
  notes       String?
  gscProperty String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectRuns ProjectRun[]

  @@index([isActive])
}

enum RunStatus {
  draft
  crawling
  crawl_complete
  fetching_gsc
  merging
  classifying
  classified
  in_review
  completed
}

model ProjectRun {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      RunStatus @default(draft)
  urlCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Crawl settings
  crawlMaxPages   Int     @default(500)
  crawlMaxDepth   Int     @default(10)
  crawlStarted    DateTime?
  crawlCompleted  DateTime?
  crawlError      String?

  // GSC settings
  gscDateRangeStart DateTime?
  gscDateRangeEnd   DateTime?
  gscFetchedAt      DateTime?

  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ruleConfigId String?
  ruleConfig   RuleConfig? @relation(fields: [ruleConfigId], references: [id])

  uploadedFiles UploadedFile[]
  urlRecords    UrlRecord[]
  crawlQueue    CrawlQueue[]

  @@index([clientId])
  @@index([status])
}

model CrawlQueue {
  id           String   @id @default(cuid())
  url          String
  depth        Int      @default(0)
  status       String   @default("pending") // pending, processing, completed, failed
  errorMessage String?
  createdAt    DateTime @default(now())

  projectRunId String
  projectRun   ProjectRun @relation(fields: [projectRunId], references: [id], onDelete: Cascade)

  @@unique([projectRunId, url])
  @@index([projectRunId, status])
}

model UploadedFile {
  id            String   @id @default(cuid())
  fileName      String
  fileType      String?
  fileSize      Int
  rowCount      Int?
  columnMapping Json?
  uploadedAt    DateTime @default(now())

  projectRunId String
  projectRun   ProjectRun @relation(fields: [projectRunId], references: [id], onDelete: Cascade)

  @@index([projectRunId])
}

model UrlRecord {
  id      String @id @default(cuid())
  url     String
  urlRaw  String

  // Crawl data
  pageType        String?
  statusCode      Int?
  indexability     String?
  canonical        String?
  metaRobots       String?
  title            String?
  metaDescription  String?
  h1               String?
  wordCount        Int?
  lastModified     DateTime?
  contentType      String?
  crawlDepth       Int?
  responseTimeMs   Int?

  // GSC data
  clicks      Int?
  impressions Int?
  ctr         Float?
  position    Float?

  // Analytics data (from CSV fallback)
  sessions   Int?
  bounceRate Float?
  conversions Int?

  // Backlink data (from CSV fallback)
  backlinks        Int?
  referringDomains Int?

  // Link structure
  internalLinksIn  Int?
  internalLinksOut Int?
  outlinks         Json?  // Array of discovered outlink URLs (for computing inlinks)

  // Derived fields
  isIndexable     Boolean?
  isOrphan        Boolean?
  isThinContent   Boolean?
  hasBacklinks    Boolean?
  hasConversions  Boolean?
  hasTraffic      Boolean?
  missingTitle    Boolean?
  missingH1       Boolean?
  dataCompleteness Float?

  // Classification results
  recommendation      String?   // KEEP_INDEXED, KEEP_INDEXED_IMPROVE, CONSIDER_NOINDEX, MANUAL_REVIEW_REQUIRED
  secondaryAction     String?   // improve_content, consolidate_pages, redirect_to_target, etc.
  confidenceScore     Float?
  primaryReason       String?
  secondaryReason     String?
  suggestedAction     String?
  suggestedTargetUrl  String?
  needsReview         Boolean @default(false)
  reviewTriggers      Json?

  scoreBreakdown Json?
  totalScore     Float?

  // Data source tracking
  dataSources Json?     // ["crawl", "gsc", "csv_crawl", "csv_gsc", etc.]
  gscMatched  Boolean?  // Whether this URL was matched in GSC data

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectRunId String
  projectRun   ProjectRun @relation(fields: [projectRunId], references: [id], onDelete: Cascade)

  reviewDecision ReviewDecision?

  @@unique([projectRunId, url])
  @@index([projectRunId, recommendation])
  @@index([projectRunId, needsReview])
  @@index([projectRunId, pageType])
}

model ReviewDecision {
  id                       String   @id @default(cuid())
  originalRecommendation   String
  finalRecommendation      String
  reason                   String?
  notes                    String?
  targetUrl                String?
  approved                 Boolean  @default(false)  // For noindex: explicit approval flag
  reviewedAt               DateTime @default(now())

  urlRecordId String    @unique
  urlRecord   UrlRecord @relation(fields: [urlRecordId], references: [id], onDelete: Cascade)
}

model RuleConfig {
  id                   String  @id @default(cuid())
  name                 String
  isDefault            Boolean @default(false)
  hardRules            Json
  scoreWeights         Json
  scoringThresholds    Json
  manualReviewTriggers Json
  pageTypeModifiers    Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  projectRuns ProjectRun[]
}
