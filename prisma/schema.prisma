generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  domain    String
  niche     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectRuns ProjectRun[]

  @@index([isActive])
}

enum RunStatus {
  draft
  processing
  classified
  in_review
  completed
}

model ProjectRun {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      RunStatus @default(draft)
  urlCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  ruleConfigId String?
  ruleConfig   RuleConfig? @relation(fields: [ruleConfigId], references: [id])

  uploadedFiles UploadedFile[]
  urlRecords    UrlRecord[]

  @@index([clientId])
  @@index([status])
}

model UploadedFile {
  id            String   @id @default(cuid())
  fileName      String
  fileType      String?
  fileSize      Int
  rowCount      Int?
  columnMapping Json?
  uploadedAt    DateTime @default(now())

  projectRunId String
  projectRun   ProjectRun @relation(fields: [projectRunId], references: [id], onDelete: Cascade)

  @@index([projectRunId])
}

model UrlRecord {
  id      String @id @default(cuid())
  url     String
  urlRaw  String

  pageType     String?
  statusCode   Int?
  indexability String?
  canonical    String?
  title        String?
  h1           String?
  wordCount    Int?
  lastModified DateTime?

  clicks      Int?
  impressions Int?
  ctr         Float?
  position    Float?

  sessions   Int?
  bounceRate Float?
  conversions Int?

  backlinks        Int?
  referringDomains Int?
  internalLinksIn  Int?
  internalLinksOut Int?

  isIndexable     Boolean?
  isOrphan        Boolean?
  isThinContent   Boolean?
  hasBacklinks    Boolean?
  hasConversions  Boolean?
  hasTraffic      Boolean?
  missingTitle    Boolean?
  missingH1       Boolean?
  dataCompleteness Float?

  classification    String?
  confidenceScore   Float?
  primaryReason     String?
  secondaryReason   String?
  suggestedAction   String?
  suggestedTargetUrl String?
  needsReview       Boolean @default(false)
  reviewTriggers    Json?

  scoreBreakdown Json?
  totalScore     Float?

  dataSources Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectRunId String
  projectRun   ProjectRun @relation(fields: [projectRunId], references: [id], onDelete: Cascade)

  reviewDecision ReviewDecision?

  @@unique([projectRunId, url])
  @@index([projectRunId, classification])
  @@index([projectRunId, needsReview])
  @@index([projectRunId, pageType])
}

model ReviewDecision {
  id                     String   @id @default(cuid())
  originalClassification String
  finalClassification    String
  reason                 String?
  notes                  String?
  targetUrl              String?
  reviewedAt             DateTime @default(now())

  urlRecordId String    @unique
  urlRecord   UrlRecord @relation(fields: [urlRecordId], references: [id], onDelete: Cascade)
}

model RuleConfig {
  id                   String  @id @default(cuid())
  name                 String
  isDefault            Boolean @default(false)
  hardRules            Json
  scoreWeights         Json
  scoringThresholds    Json
  manualReviewTriggers Json
  pageTypeModifiers    Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  projectRuns ProjectRun[]
}
